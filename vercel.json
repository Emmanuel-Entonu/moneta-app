{
  "rewrites": [
    { "source": "/moneta-proxy/api/v2/:path*", "destination": "https://api.moneta.ng/api/v2/:path*" },
    { "source": "/moneta-proxy/api/v1/:path*", "destination": "https://app.moneta.ng/api/v1/:path*" },
    { "source": "/mds-proxy/:path*",    "destination": "https://mywealth.mds.sandbox.mywealthcare.io/:path*" },
    { "source": "/broker-proxy/:path*", "destination": "https://mywealth.mds.sandbox.mywealthcare.io/:path*" },
    { "source": "/(.*)",                "destination": "/index.html" }
  ]
}
